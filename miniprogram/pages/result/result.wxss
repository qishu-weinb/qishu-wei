page {
  background-color: #f5f9ff;
  min-height: 100%;
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.08);
  border-radius: 50%;
}

.back-icon {
  font-size: 48rpx;
  color: #1a1a1a;
  font-weight: bold;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.more-icon {
  font-size: 36rpx;
  color: #1a1a1a;
}

.result-section {
  padding: 0 40rpx;
}

.diagnosis-row {
  display: flex;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.diagnosis-item {
  flex: 1;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-width: 4rpx;
  border-style: solid;
  border-color: transparent;
}

.diagnosis-item.active {
  border-color: rgb(30, 136, 229);
  background-color: rgba(30, 136, 229, 0.05);
}

.diagnosis-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgb(30, 136, 229);
  color: #fff;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.diagnosis-item:not(.active) .diagnosis-icon {
  background-color: #f0f0f0;
}

.diagnosis-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.confidence-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.confidence-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.confidence-value {
  font-size: 48rpx;
  font-weight: bold;
  color: rgb(30, 136, 229);
}

.confidence-label {
  font-size: 28rpx;
  color: #999;
}

.detail-btn {
  width: 160rpx;
  height: 72rpx;
  background-color: rgb(30, 136, 229);
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
}

.detail-btn::after {
  border: none;
}

.summary-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.summary-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.summary-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.knowledge-section {
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.knowledge-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 16rpx;
}

.knowledge-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-bottom-width: 2rpx;
  border-bottom-style: solid;
  border-bottom-color: #f0f0f0;
}

.knowledge-item:last-child {
  border-bottom: none;
}

.knowledge-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.knowledge-content {
  flex: 1;
}

.knowledge-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.knowledge-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.accuracy-section {
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.accuracy-card {
  display: flex;
  justify-content: space-around;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.accuracy-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.accuracy-value {
  font-size: 40rpx;
  font-weight: bold;
  color: rgb(30, 136, 229);
}

.accuracy-label {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.expert-btn {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  height: 100rpx;
  background: linear-gradient(135deg, rgb(30, 136, 229) 0%, rgb(66, 165, 245) 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
}

.expert-btn::after {
  border: none;
}