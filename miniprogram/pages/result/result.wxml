<view class="container">
  <view class="header-bar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="header-title">结果</text>
    <text class="more-icon">···</text>
  </view>
  
  <view class="result-section" wx:if="{{hasResult}}">
    <view class="source-card" wx:if="{{imagePath}}">
      <text class="summary-title">本次上传图像</text>
      <image class="source-image" src="{{imagePath}}" mode="widthFix"></image>
    </view>

    <view class="diagnosis-row">
      <view class="diagnosis-item {{result === 'normal' ? 'active' : ''}}">
        <view class="diagnosis-icon">{{result === 'normal' ? '✓' : ''}}</view>
        <text class="diagnosis-label">正常</text>
      </view>
      <view class="diagnosis-item {{result === 'benign' ? 'active' : ''}}">
        <view class="diagnosis-icon">{{result === 'benign' ? '✓' : ''}}</view>
        <text class="diagnosis-label">良性</text>
      </view>
      <view class="diagnosis-item {{result === 'malignant' ? 'active malignant-active' : ''}}">
        <view class="diagnosis-icon">{{result === 'malignant' ? '✓' : ''}}</view>
        <text class="diagnosis-label">恶性</text>
      </view>
    </view>
    
    <view class="confidence-section">
      <view class="confidence-item">
        <text class="confidence-value">{{confidence}}%</text>
        <text class="confidence-label">置信度</text>
      </view>
      <button class="detail-btn">详情</button>
    </view>

    <view class="probability-card">
      <text class="probability-title">模型概率</text>
      <view class="probability-row"><text>正常</text><text>{{probabilities.normal}}%</text></view>
      <view class="probability-row"><text>良性</text><text>{{probabilities.benign}}%</text></view>
      <view class="probability-row"><text>恶性</text><text>{{probabilities.malignant}}%</text></view>
    </view>

    <view class="mask-card" wx:if="{{maskUrl}}">
      <text class="summary-title">病灶分割参考</text>
      <image class="mask-image" src="{{maskUrl}}" mode="widthFix"></image>
      <text class="mask-tip">白色区域为模型识别的病灶区域，仅供参考</text>
    </view>
    
    <view class="summary-card">
      <text class="summary-title">检测结果摘要</text>
      <text class="summary-content">{{summaryContent}}</text>
    </view>
  </view>

  <view class="result-section" wx:else>
    <view class="summary-card">
      <text class="summary-title">暂不能生成诊断结果</text>
      <text class="summary-content">{{summaryContent}}</text>
      <text class="summary-content">{{suggestion}}</text>
    </view>
  </view>
  
  <view class="knowledge-section">
    <text class="section-title">相关知识</text>
    
    <view class="knowledge-card">
      <view class="knowledge-item">
        <view class="knowledge-icon">📚</view>
        <view class="knowledge-content">
          <text class="knowledge-title">乳腺癌早期症状</text>
          <text class="knowledge-desc">乳房肿块、乳头溢液、皮肤改变、乳头异常</text>
        </view>
      </view>
      
      <view class="knowledge-item">
        <view class="knowledge-icon">📋</view>
        <view class="knowledge-content">
          <text class="knowledge-title">病理检查的重要性</text>
          <text class="knowledge-desc">病理诊断是乳腺癌诊断的金标准，可明确肿瘤性质和类型</text>
        </view>
      </view>
      
      <view class="knowledge-item">
        <view class="knowledge-icon">💡</view>
        <view class="knowledge-content">
          <text class="knowledge-title">AI辅助诊断优势</text>
          <text class="knowledge-desc">提高诊断效率、减少人为误差、支持远程诊断</text>
        </view>
      </view>
      
      <view class="knowledge-item">
        <view class="knowledge-icon">🏥</view>
        <view class="knowledge-content">
          <text class="knowledge-title">后续诊疗建议</text>
          <text class="knowledge-desc">及时咨询专科医生，制定个性化治疗方案</text>
        </view>
      </view>
    </view>
  </view>
  
  <button class="expert-btn" wx:if="{{hasResult}}" bindtap="goToExpert">专家解读</button>
  <button class="expert-btn" wx:else bindtap="goToHome">返回首页</button>
</view>
