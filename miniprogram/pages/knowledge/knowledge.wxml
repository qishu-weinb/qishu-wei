<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="page-title">健康知识</text>
    <view class="header-right"></view>
  </view>
  
  <view class="content">
    <view class="knowledge-section">
      <view class="article-card" wx:for="{{articles}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="article-header">
          <text class="article-tag">{{item.tag}}</text>
          <text class="article-date">{{item.createdAt}}</text>
        </view>
        <text class="article-title">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <view class="article-footer">
          <text class="article-read">阅读全文 ›</text>
        </view>
      </view>
      <view class="article-card" wx:if="{{articles.length === 0}}">
        <text class="article-title">暂无健康知识</text>
        <text class="article-summary">后端服务启动后会初始化健康知识内容。</text>
      </view>
    </view>
  </view>
</view>
