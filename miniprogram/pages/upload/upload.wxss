page {
  background: linear-gradient(180deg, #2082F0 0%, #4A9BE8 40%, #E8F4FD 100%);
  min-height: 100%;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 32rpx 32rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.back-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.header-right {
  width: 64rpx;
}

.main-section {
  padding: 32rpx;
}

.image-card {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.08);
}

.diagnosis-image {
  width: 100%;
  max-width: 500rpx;
  height: 400rpx;
  margin-bottom: 32rpx;
}

.upload-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #2082F0 0%, #4A9BE8 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
}

.upload-btn::after {
  border: none;
}

.info-card {
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 32rpx;
}

.info-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.info-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.upload-preview {
  margin: 32rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.08);
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.preview-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.preview-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.preview-image {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.confirm-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #2082F0 0%, #4A9BE8 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
}

.confirm-btn::after {
  border: none;
}
