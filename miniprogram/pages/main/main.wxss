page {
  background-color: #f5f9ff;
  min-height: 100%;
}

.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.header-section {
  background-color: #2082F0;
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 32rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-action {
  font-size: 32rpx;
}

.banner-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.banner-content {
  flex: 1;
}

.banner-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.banner-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.banner-btn {
  background-color: #00C853;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
  margin-top: 24rpx;
}

.banner-btn::after {
  border: none;
}

.banner-image {
  width: 240rpx;
  height: 200rpx;
}

.content-section {
  padding: 32rpx;
}

.function-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.function-item {
  width: 30%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.function-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.function-icon-wrap.blue {
  background-color: #1E88E5;
}

.function-icon-wrap.orange {
  background-color: #1976D2;
}

.function-icon-wrap.blue-light {
  background-color: #42A5F5;
}

.function-icon-wrap.cyan-dark {
  background-color: #00ACC1;
}

.function-icon-wrap.blue-dark {
  background-color: #1565C0;
}

.function-icon {
  font-size: 56rpx;
  color: #fff;
}

.function-name {
  font-size: 26rpx;
  color: #333;
}

.history-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 16rpx;
}

.history-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.history-icon.benign {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.history-icon.malignant {
  background-color: #FFF3E0;
  color: #FF9800;
}

.history-info {
  flex: 1;
}

.history-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.history-date {
  font-size: 24rpx;
  color: #999;
}

.history-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: #fff;
  padding: 20rpx 0 40rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.tab-name {
  font-size: 24rpx;
  color: #999;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}

.tab-item.active .tab-name {
  color: #2082F0;
  font-weight: bold;
}
