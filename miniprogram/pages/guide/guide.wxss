page {
  background-color: #f5f9ff;
  min-height: 100%;
}

.container {
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 32rpx 32rpx;
  background-color: #fff;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.08);
  border-radius: 50%;
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: bold;
}

.page-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.header-right {
  width: 64rpx;
}

.content {
  padding: 32rpx;
}

.guide-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}

.card-content {
  flex: 1;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.card-desc:last-child {
  margin-bottom: 0;
}