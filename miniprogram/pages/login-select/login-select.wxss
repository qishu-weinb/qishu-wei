page {
  background-color: #f5f9ff;
  min-height: 100%;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.bg-section {
  flex: 1;
  position: relative;
  overflow: hidden;
}

.bg-image {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(32, 130, 240, 0.9) 0%, rgba(32, 130, 240, 0.7) 100%);
}

.content-section {
  padding: 40rpx 48rpx;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  font-size: 34rpx;
  font-weight: bold;
}

.login-btn::after {
  border: none;
}

.login-btn.phone {
  background-color: #2082F0;
  color: #fff;
}

.login-btn.wechat {
  background-color: #fff;
  color: #2082F0;
  border: 2rpx solid #2082F0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
}

.wechat-text {
  font-weight: bold;
}

.agreement-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 32rpx;
}
