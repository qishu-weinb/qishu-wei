page {
  background-color: #f5f9ff;
  min-height: 100%;
}

.container {
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
}

.back-icon {
  font-size: 48rpx;
  color: #1a1a1a;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.header-right {
  width: 80rpx;
}

.form-card {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  margin: 0 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-input-wrapper {
  position: relative;
}

.form-input {
  width: 100%;
  height: 96rpx;
  border-width: 2rpx;
  border-style: solid;
  border-color: #e0e0e0;
  border-radius: 48rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.password-toggle {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  z-index: 10;
  pointer-events: auto;
}

.get-code-btn {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 180rpx;
  height: 72rpx;
  background-color: rgb(30, 136, 229);
  color: #fff;
  font-size: 26rpx;
  border-radius: 36rpx;
  border: none;
}

.get-code-btn::after {
  border: none;
}

.get-code-btn[disabled] {
  background-color: #ccc;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, rgb(30, 136, 229) 0%, rgb(66, 165, 245) 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  margin-top: 20rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

.form-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 32rpx;
}

.forgot-pwd {
  font-size: 28rpx;
  color: #999;
}

.register-link {
  font-size: 28rpx;
  color: rgb(30, 136, 229);
}